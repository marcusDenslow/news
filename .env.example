# --- News Hub configuration ---
# Copy to .env and fill in. docker-compose reads these.

# Miniflux admin login, created on first run. Change before first start.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Miniflux API token. setup.sh mints this automatically — leave blank.
MINIFLUX_TOKEN=

# Shared secret the browser extension presents to push captured articles.
# Generate one:  openssl rand -hex 24
CAPTURE_TOKEN=

# Host port for the reader (or pass setup.sh --port N).
WEB_PORT=3000

# --- Server-side (headless) fetch mode — OPTIONAL, leave blank to keep off ---
# Encryption key for stored publisher cookies. Setting this turns on the
# no-browser fetch worker. Generate:  openssl rand -hex 32
NEWSHUB_SECRET_KEY=
# For JS-heavy paywalls: set to http://renderer:4000 AND start with
#   docker compose --profile heavy up -d
NEWSHUB_RENDERER_URL=
# Minutes between server-side backfill passes (min 5).
NEWSHUB_BACKFILL_MIN=15
